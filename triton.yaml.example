server:
  listen: ":4433"
  listen_tcp: ":8443"
  dashboard: true
  dashboard_listen: "127.0.0.1:9090"
  read_timeout: 15s
  write_timeout: 30s
  idle_timeout: 30s

probe:
  timeout: 10s
  insecure: false
  default_tests:
    - handshake
    - tls
    - latency
  default_format: table
  download_size: 1MB
  upload_size: 1MB
  default_streams: 10

bench:
  warmup: 2s
  default_duration: 10s
  default_concurrency: 10
  default_protocols:
    - h1
    - h2

storage:
  results_dir: ./triton-data
  max_results: 1000
  retention: 720h
